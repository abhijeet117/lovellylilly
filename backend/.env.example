PORT=5000
NODE_ENV=development
MONGO_URI=your-mongodb-connection-string
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# AI Models — Mistral is the primary chat provider
MISTRAL_API_KEY=your-mistral-key
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key
DEFAULT_AI_PROVIDER=mistral
DEFAULT_AI_MODEL=mistral-large-latest
# Image/video generation via Pollinations.ai (free tier available, key removes rate limits)
POLLINATIONS_API_KEY=your-pollinations-key

# Features
MAX_FILE_SIZE_MB=20
TAVILY_API_KEY=your-tavily-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# PinchTab Browser Agent (Prompt 2)
PINCHTAB_URL=http://localhost:9867
